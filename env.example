# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=UKMAC Website API
APP_VERSION=1.0.0
APP_ENVIRONMENT=development

# Comma-separated browser origins allowed to call the API.
# Use origins only, without paths. Example local values can be added when needed:
# https://your-admin-domain.com,http://localhost:3000
CORS_ORIGINS=https://your-admin-domain.com

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Generate a strong value, for example: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Server-side only. Never expose this key in browser code or commit it to Git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Supabase resources
# -----------------------------------------------------------------------------
SUPABASE_PROFILE_TABLE=profiles
SUPABASE_POST_TYPES_TABLE=post_types
SUPABASE_POSTS_TABLE=posts
SUPABASE_IMAGES_TABLE=images
SUPABASE_QR_LINKS_TABLE=qr_links
SUPABASE_STORAGE_BUCKET=website
